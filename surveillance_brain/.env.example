# ──────────────────────────────────────────────────────────────────────────
# Surveillance Brain (Project RUNG01 — Part 2) — environment template
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and edit as needed.  Every variable has a working
# default matching docker-compose.yml — `docker compose up` works with ZERO
# edits.  Override only sensitive values before any non-local deployment.
# ──────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL 16 (structured records + logs) ─────────────────────────────
POSTGRES_USER=surveillance
POSTGRES_PASSWORD=surveillance
POSTGRES_DB=surveillance
POSTGRES_HOST=localhost      # use "postgres" inside the app container
POSTGRES_PORT=5432

# ─── Qdrant (face + body embedding vector DB) ──────────────────────────────
QDRANT_HOST=localhost        # use "qdrant" inside the app container
QDRANT_PORT=6333
QDRANT_API_KEY=              # leave empty for the bundled compose setup
QDRANT_FACE_COLLECTION=faces
QDRANT_BODY_COLLECTION=bodies

# ─── Redis (live presence cache + duplicate guard) ─────────────────────────
REDIS_HOST=localhost         # use "redis" inside the app container
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── Matching thresholds ───────────────────────────────────────────────────
# Part 1 sends detection_conf in the 0.0–1.0 range. Below this → UNKNOWN
# (no vector search).  ">80%" == 0.80.
DETECTION_CONF_THRESHOLD=0.80

# Cosine similarity floors (Qdrant score). Face is primary; body is fallback.
FACE_SIMILARITY_THRESHOLD=0.65
BODY_SIMILARITY_THRESHOLD=0.60

# MUST match Part 1's model output dimension (face + body share it here).
EMBEDDING_DIMENSIONS=512

# ─── Local storage (JSON/JSONL export/archive) ─────────────────────────────
STORAGE_ROOT=storage
LOG_DIR=storage/logs
DATASHEET_DIR=storage/datasheet

# ─── Session + cron behaviour ──────────────────────────────────────────────
# TTL on the Redis live-presence hash (seconds). Only place a TTL applies —
# Postgres records are permanent.
SESSION_TIMEOUT_SECONDS=300

# Suppress repeat ledger writes for the same person+camera within N seconds.
DUPLICATE_WINDOW_SECONDS=30

# APScheduler cron expressions (UTC).
MIDNIGHT_FLUSH_CRON=0 0 * * *      # close dangling sessions at 00:00
ARCHIVE_CRON=*/30 * * * *          # export logs + datasheet every 30 min

# ─── Admin Basic-Auth ──────────────────────────────────────────────────────
# CHANGE THESE before any non-local deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Runtime ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=dev               # dev | prod

# Set to "0" to disable the background schedulers (used in tests).
ENABLE_MIDNIGHT_FLUSH=1
